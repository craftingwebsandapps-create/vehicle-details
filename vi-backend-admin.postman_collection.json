{
  "info": {
    "_postman_id": "a7c3e9b2-5f01-4c8d-9e2a-vi-backend-admin",
    "name": "VI Backend — Admin (approval API)",
    "description": "Superadmin-only routes under `/api/admin`. JWT must have **no** `contractorId` (tenant users get `FORBIDDEN_SUPERADMIN_ONLY`).\n\n1. Set **baseUrl** (e.g. `http://localhost:6600` or your prod host).\n2. Run **Login (superadmin)** — tokens are saved to collection variables.\n3. Set **vehicleId** / **siteId** / **driverId** to real 24-char hex Mongo ids, then call approve/reject.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:6600" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "vehicleId", "value": "507f1f77bcf86cd799439011" },
    { "key": "siteId", "value": "507f191e810c19729de860ea" },
    { "key": "driverId", "value": "507f191e810c19729de860eb" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Public liveness check (also available at `GET {{baseUrl}}/api/health`)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/health"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"status\": \"ok\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login (superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (pm.response.code === 200 && j.success && j.data) {",
                  "  pm.collectionVariables.set('accessToken', j.data.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', j.data.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@example.com\",\n  \"password\": \"change-me-8chars-min\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "User must be registered **without** `contractorId` so JWT has no tenant → superadmin."
          },
          "response": [
            {
              "name": "Example — tokens",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret-password\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/login"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refreshToken\": \"base64url.refresh.token.example\",\n    \"expiresIn\": 900\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh tokens",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "Rotate refresh token; updates **accessToken** in response (copy into **accessToken** variable if not scripting)."
          },
          "response": [
            {
              "name": "Example — new pair",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"previous-refresh-token\"\n}"
                },
                "url": "{{baseUrl}}/api/auth/refresh"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"accessToken\": \"eyJhbGc...\",\n    \"refreshToken\": \"new-base64url-token\",\n    \"expiresIn\": 900\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin — approval",
      "description": "All routes require `Authorization: Bearer {{accessToken}}` with a **superadmin** user.",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Vehicles",
          "item": [
            {
              "name": "List vehicles",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/contractor/vehicles?page=1&limit=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "contractor", "vehicles"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "20" },
                    { "key": "search", "value": "", "disabled": true },
                    { "key": "approvalStatus", "value": "PENDING_APPROVAL", "disabled": true },
                    { "key": "status", "value": "ACTIVE", "disabled": true }
                  ]
                },
                "description": "Same route as the contractor app: `GET /api/v1/contractor/vehicles`. With a **superadmin** JWT (no `contractorId`), the backend should return vehicles across tenants. Query params: `page`, `limit`, `search`, `name`, `site`, `type`, `registrationNumber`, `status`, `approvalStatus`."
              },
              "response": []
            },
            {
              "name": "Approve vehicle",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "" },
                "url": "{{baseUrl}}/api/admin/vehicles/{{vehicleId}}/approve",
                "description": "`id` path param: 24-character hex MongoDB ObjectId."
              },
              "response": [
                {
                  "name": "Example — approved vehicle",
                  "originalRequest": {
                    "method": "POST",
                    "header": [],
                    "url": "{{baseUrl}}/api/admin/vehicles/507f1f77bcf86cd799439011/approve"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f1f77bcf86cd799439011\",\n    \"approvalStatus\": \"approved\",\n    \"registrationNumber\": \"AP09AB1234\"\n  }\n}"
                }
              ]
            },
            {
              "name": "Reject vehicle",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"note\": \"Documents unclear; please resubmit registration proof.\"\n}"
                },
                "url": "{{baseUrl}}/api/admin/vehicles/{{vehicleId}}/reject",
                "description": "Body is optional. `note` optional string, max 2000 chars trimmed."
              },
              "response": [
                {
                  "name": "Example — rejected",
                  "originalRequest": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"note\": \"Incomplete paperwork\"\n}"
                    },
                    "url": "{{baseUrl}}/api/admin/vehicles/507f1f77bcf86cd799439011/reject"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f1f77bcf86cd799439011\",\n    \"approvalStatus\": \"rejected\",\n    \"approvalNote\": \"Incomplete paperwork\"\n  }\n}"
                },
                {
                  "name": "Example — empty body (allowed)",
                  "originalRequest": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": { "mode": "raw", "raw": "{}" },
                    "url": "{{baseUrl}}/api/admin/vehicles/507f1f77bcf86cd799439011/reject"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f1f77bcf86cd799439011\",\n    \"approvalStatus\": \"rejected\"\n  }\n}"
                }
              ]
            }
          ]
        },
        {
          "name": "Sites",
          "item": [
            {
              "name": "Approve site",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "" },
                "url": "{{baseUrl}}/api/admin/sites/{{siteId}}/approve"
              },
              "response": [
                {
                  "name": "Example",
                  "originalRequest": {
                    "method": "POST",
                    "header": [],
                    "url": "{{baseUrl}}/api/admin/sites/507f191e810c19729de860ea/approve"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f191e810c19729de860ea\",\n    \"approvalStatus\": \"approved\",\n    \"name\": \"North Depot\"\n  }\n}"
                }
              ]
            },
            {
              "name": "Reject site",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"note\": \"Location verification failed\"\n}"
                },
                "url": "{{baseUrl}}/api/admin/sites/{{siteId}}/reject"
              },
              "response": [
                {
                  "name": "Example",
                  "originalRequest": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"note\": \"Location verification failed\"\n}"
                    },
                    "url": "{{baseUrl}}/api/admin/sites/507f191e810c19729de860ea/reject"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f191e810c19729de860ea\",\n    \"approvalStatus\": \"rejected\",\n    \"approvalNote\": \"Location verification failed\"\n  }\n}"
                }
              ]
            }
          ]
        },
        {
          "name": "Drivers",
          "item": [
            {
              "name": "Approve driver",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "" },
                "url": "{{baseUrl}}/api/admin/drivers/{{driverId}}/approve"
              },
              "response": [
                {
                  "name": "Example",
                  "originalRequest": {
                    "method": "POST",
                    "header": [],
                    "url": "{{baseUrl}}/api/admin/drivers/507f191e810c19729de860eb/approve"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f191e810c19729de860eb\",\n    \"approvalStatus\": \"approved\",\n    \"name\": \"Ravi Kumar\"\n  }\n}"
                }
              ]
            },
            {
              "name": "Reject driver",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"note\": \"License expiry invalid\"\n}"
                },
                "url": "{{baseUrl}}/api/admin/drivers/{{driverId}}/reject"
              },
              "response": [
                {
                  "name": "Example",
                  "originalRequest": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"note\": \"License expiry invalid\"\n}"
                    },
                    "url": "{{baseUrl}}/api/admin/drivers/507f191e810c19729de860eb/reject"
                  },
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "header": [],
                  "cookie": [],
                  "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"507f191e810c19729de860eb\",\n    \"approvalStatus\": \"rejected\",\n    \"approvalNote\": \"License expiry invalid\"\n  }\n}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
