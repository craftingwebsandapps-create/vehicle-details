                  "raw": "{\n  \"name\": \"New Driver\",\n  \"licenceNumber\": \"AP092024009999\",\n  \"licenceUrl\": \"https://docs.example.com/licences/new-driver.pdf\",\n  \"mobileNumber\": \"9871119999\",\n  \"status\": \"ACTIVE\"\n}"
